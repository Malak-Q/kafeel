# Environment Configuration
NODE_ENV=development
PORT=3000

# Database Configuration - SQLite for development
DB_CLIENT=sqlite3
DB_FILENAME=./kafeel_dev.sqlite

# JWT Configuration
JWT_SECRET=kafeel_jwt_secret_key_development_12345
JWT_EXPIRES_IN=24h

# Bahrain e-Key Integration
EKEY_API_URL=https://api.bahrain.gov.bh/ekey
EKEY_CLIENT_ID=dev_ekey_client_id
EKEY_CLIENT_SECRET=dev_ekey_client_secret

# Open Banking Configuration
CBB_API_URL=https://api.cbb.gov.bh
CBB_CLIENT_ID=dev_cbb_client_id
CBB_CLIENT_SECRET=dev_cbb_client_secret

# Security
ENCRYPTION_KEY=kafeel_encryption_key_32_chars
SALT_ROUNDS=12

# Logging
LOG_LEVEL=info
LOG_FILE_PATH=./logs/app.log

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
